class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        i,j=0,1
        profit=0
        n=len(prices)
        for j in range(n):
            profit=max(profit,prices[j]-prices[i])
            if(prices[j]<prices[i]):
                i=j
                j=j+1
            else:
                j=j+1
        return profit

        
